{
  "name": "gym",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:github": "oxlint --format=github",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "db:generate": "bun --bun prisma generate",
    "db:migrate": "bun --bun prisma migrate dev",
    "db:migrate:deploy": "bun --bun prisma migrate deploy",
    "db:studio": "bun --bun prisma studio",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:run": "vitest run --project unit",
    "test:run:e2e": "vitest run --project e2e",
    "test:watch": "vitest watch",
    "test:watch:unit": "vitest watch --project unit",
    "test:watch:e2e": "vitest watch --project e2e",
    "test:ui": "vitest --ui",
    "test:ui:unit": "vitest --ui --project unit",
    "test:ui:e2e": "vitest --ui --project e2e",
    "test:coverage": "vitest run --coverage",
    "test:coverage:unit": "vitest run --coverage --project unit",
    "test:coverage:e2e": "vitest run --coverage --project e2e",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "test:ci:unit": "vitest run --project unit --coverage --reporter=verbose",
    "test:ci:e2e": "vitest run --project e2e --reporter=verbose"
  },
  "dependencies": {
    "@fastify/jwt": "10.0.0",
    "@fastify/swagger": "9.7.0",
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "7.6.0",
    "@prisma/extension-accelerate": "3.0.1",
    "@scalar/fastify-api-reference": "1.55.1",
    "bcrypt": "6.0.0",
    "fastify": "5.8.4",
    "fastify-type-provider-zod": "6.1.0",
    "pg": "8.20.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "6.0.0",
    "@types/bun": "latest",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.1.3",
    "@vitest/ui": "4.1.3",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "pino-pretty": "13.1.3",
    "prisma": "7.6.0",
    "vite": "8.0.10",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.3"
  }
}
