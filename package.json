{
  "name": "gym",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:github": "oxlint --format=github",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "db:generate": "bun --bun prisma generate",
    "db:migrate": "bun --bun prisma migrate dev",
    "db:studio": "bun --bun prisma studio",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "bun --bun vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "7.6.0",
    "@prisma/extension-accelerate": "3.0.1",
    "bcrypt": "6.0.0",
    "fastify": "5.8.4",
    "pg": "8.20.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "6.0.0",
    "@types/bun": "latest",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.1.3",
    "@vitest/ui": "4.1.3",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "pino-pretty": "13.1.3",
    "prisma": "7.6.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.3"
  }
}
